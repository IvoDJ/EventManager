{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "dotnet publish src/EventManager.WebApi/EventManager.WebApi.csproj -c Release -o out"
  },
  "deploy": {
    "startCommand": "dotnet out/EventManager.WebApi.dll",
    "restartPolicyType": "ON_FAILURE"
  }
}