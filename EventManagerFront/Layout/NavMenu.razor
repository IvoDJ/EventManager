@inject IJSRuntime JS
@inject NavigationManager Nav
@inject EventManagerFront.Services.AuthService AuthService

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="dashboard">EventManager</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="nav flex-column">
        @if (isLoggedIn)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="dashboard">
                    Mis Eventos
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <button class="nav-link btn btn-link" @onclick="Logout">
                    Cerrar Sesión
                </button>
            </div>
        }
        else
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="login">
                    Iniciar Sesión
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="register">
                    Registrarse
                </NavLink>
            </div>
        }
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;
    private bool isLoggedIn = false;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    protected override async Task OnInitializedAsync()
    {
        AuthService.OnChange += UpdateLoginState;
        var token = await JS.InvokeAsync<string>("storage.get", "token");
        isLoggedIn = !string.IsNullOrEmpty(token);
    }

    private void UpdateLoginState()
    {
        isLoggedIn = AuthService.IsLoggedIn;
        StateHasChanged();
    }

    private async Task Logout()
    {
        await JS.InvokeVoidAsync("storage.set", "token", "");
        AuthService.SetLoggedIn(false);
        Nav.NavigateTo("/login");
    }
}