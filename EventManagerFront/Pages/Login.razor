@page "/login"
@using EventManagerFront.Models
@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject EventManagerFront.Services.AuthService AuthService

<h1>Event Manager V0.1</h1>
<h2>Iniciar sesión</h2>

<input @bind="username" placeholder="Usuario" />
<input type="password" @bind="password" placeholder="Contraseña" />
<button @onclick="HandleLogin">Ingresar</button>

@if (!string.IsNullOrEmpty(error))
{
    <p style="color:red">@error</p>
}

@code {
    private string username = "";
    private string password = "";
    private string error = "";

    private async Task HandleLogin()
    {
        try
        {
            var response = await Http.PostAsJsonAsync("/dj/login", new { username, password });
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<LoginResponse>();
                await JS.InvokeVoidAsync("storage.set", "token", result!.Token);
                AuthService.SetLoggedIn(true);
                Nav.NavigateTo("/dashboard");
            }
            else
            {
                error = "Credenciales inválidas";
            }
        }
        catch
        {
            error = "Error al conectar con el servidor";
        }
    }
}