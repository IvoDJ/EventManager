@page "/login"
@using EventManagerFront.Models
@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject EventManagerFront.Services.AuthService AuthService

<div class="login-container">
    <div class="login-card">
        <h1>Event Manager</h1>
        <h2>Iniciar sesión</h2>

        <input class="login-input" @bind="username" placeholder="Usuario" />
        <input class="login-input" type="password" @bind="password" placeholder="Contraseña" />
        
        <button class="btn-login" @onclick="HandleLogin">Ingresar</button>

        <div class="register-link">
            <span>¿No estás registrado?</span>
            <button class="btn-link" @onclick='() => Nav.NavigateTo("/register")'>Registrate</button>
        </div>

        @if (!string.IsNullOrEmpty(error))
        {
            <p class="error-msg">@error</p>
        }
    </div>
</div>

@code {
    private string username = "";
    private string password = "";
    private string error = "";

    private async Task HandleLogin()
    {
        try
        {
            var response = await Http.PostAsJsonAsync("/dj/login", new { username, password });
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<LoginResponse>();
                await JS.InvokeVoidAsync("storage.set", "token", result!.Token);
                AuthService.SetLoggedIn(true);
                Nav.NavigateTo("/dashboard");
            }
            else
            {
                error = "Credenciales inválidas";
            }
        }
        catch
        {
            error = "Error al conectar con el servidor";
        }
    }
}