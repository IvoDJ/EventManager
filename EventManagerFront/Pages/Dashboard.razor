@page "/dashboard"
@using EventManagerFront.Models
@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject EventManagerFront.Services.AuthService AuthService

<div class="dashboard-container">
    <div class="dashboard-header">
        <h1>Mis Eventos</h1>
        <button class="btn-small" @onclick='() => Nav.NavigateTo("/add-event")'>
            + Agregar Evento
        </button>
    </div>

    @if (events == null)
    {
        <p class="text-muted">Cargando...</p>
    }
    else if (events.Count == 0)
    {
        <p class="text-muted">No tenés eventos cargados</p>
    }
    else
    {
        <div class="events-grid">
            @foreach (var e in events)
            {
                <div class="event-card">
                    <div class="event-card-header">
                        <h3>@e.Type</h3>
                    </div>
                    <div class="event-card-body">
                        <p>📅 @e.Date.ToLocalTime().ToString("dd/MM/yyyy")</p>
                        <p>📍 @e.Loc</p>
                    </div>
                    <div class="event-card-footer">
                        <button class="btn-detail" 
                                @onclick='() => Nav.NavigateTo($"/event/{e.Id}")'>
                            Ver detalle
                        </button>
                        <button class="btn-delete" 
                                @onclick="() => DeleteEvent(e.Id)">
                            Eliminar
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<EventDto>? events;

    protected override async Task OnInitializedAsync()
    {
        var token = await JS.InvokeAsync<string>("storage.get", "token");
        
        if (string.IsNullOrEmpty(token))
        {
            Nav.NavigateTo("/login");
            return;
        }

        Http.DefaultRequestHeaders.Authorization = 
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
        AuthService.SetLoggedIn(true);


        var response = await Http.GetFromJsonAsync<EventsResponse>("/dj/event");
        events = response?.Events ?? new List<EventDto>();
    }
    private async Task DeleteEvent(Guid id)
{
    var token = await JS.InvokeAsync<string>("storage.get", "token");
    Http.DefaultRequestHeaders.Authorization =
        new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

    var response = await Http.DeleteAsync($"/dj/event/{id}");
    if (response.IsSuccessStatusCode)
    {
        events = events?.Where(e => e.Id != id).ToList();
    }
}
private async Task Logout()
{
    await JS.InvokeVoidAsync("storage.set", "token", "");
    AuthService.SetLoggedIn(false);
    Nav.NavigateTo("/login");
}
}