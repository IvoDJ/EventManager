@page "/register"
@using EventManagerFront.Models
@inject HttpClient Http
@inject NavigationManager Nav

<div class="login-container">
    <div class="login-card">
        <h1>Event Manager</h1>
        <h2>Registro de DJ</h2>

        <input class="login-input" @bind="name" placeholder="Nombre artístico" />
        <input class="login-input" @bind="username" placeholder="Usuario" />
        <input class="login-input" type="password" @bind="password" placeholder="Contraseña" />

        <button class="btn-login" @onclick="HandleRegister">Registrarse</button>

        <div class="register-link">
            <span>¿Ya tenés cuenta?</span>
            <button class="btn-link" @onclick='() => Nav.NavigateTo("/login")'>Iniciá sesión</button>
        </div>

        @if (!string.IsNullOrEmpty(error))
        {
            <p class="error-msg">@error</p>
        }
    </div>
</div>

@code {
    private string name = "";
    private string username = "";
    private string password = "";
    private string error = "";

    private async Task HandleRegister()
    {
        try
        {
            var response = await Http.PostAsJsonAsync("/dj", new { name, username, password });
            if (response.IsSuccessStatusCode)
            {
                Nav.NavigateTo("/login");
            }
            else
            {
                var msg = await response.Content.ReadAsStringAsync();
                error = msg;
            }
        }
        catch
        {
            error = "Error al conectar con el servidor";
        }
    }
}