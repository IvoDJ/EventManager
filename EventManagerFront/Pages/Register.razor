@page "/register"
@using EventManagerFront.Models
@inject HttpClient Http
@inject NavigationManager Nav

<h1>Registro de Usuario</h1>

<input @bind="name" placeholder="Nombre artístico" />
<input @bind="username" placeholder="Usuario" />
<input type="password" @bind="password" placeholder="Contraseña" />
<button @onclick="HandleRegister">Registrarse</button>
<button @onclick='() => Nav.NavigateTo("/login")'>Ya tengo cuenta</button>

@if (!string.IsNullOrEmpty(error))
{
    <p style="color:red">@error</p>
}
@if (!string.IsNullOrEmpty(success))
{
    <p style="color:green">@success</p>
}

@code {
    private string name = "";
    private string username = "";
    private string password = "";
    private string error = "";
    private string success = "";

    private async Task HandleRegister()
    {
        try
        {
            var response = await Http.PostAsJsonAsync("/dj", new { name, username, password });
            if (response.IsSuccessStatusCode)
            {
                success = "Usuario registrado correctamente";
                Nav.NavigateTo("/login");
            }
            else
            {
                var msg = await response.Content.ReadAsStringAsync();
                error = msg;
            }
        }
        catch
        {
            error = "Error al conectar con el servidor";
        }
    }
}